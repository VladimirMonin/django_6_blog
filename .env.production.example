# Copy to .env.production for local preparation only.
# The live copy belongs at /etc/django-6-blog/django-6-blog.env (root:django-blog 0640).
# Never commit a populated file.
DJANGO_SETTINGS_MODULE=config.settings_production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=REPLACE_WITH_RANDOM_VALUE_AT_LEAST_50_CHARACTERS
DJANGO_ALLOWED_HOSTS=REPLACE_WITH_DOMAIN
DJANGO_CSRF_TRUSTED_ORIGINS=https://REPLACE_WITH_DOMAIN
SITE_AUTHOR=REPLACE_WITH_PUBLIC_AUTHOR_NAME

# PostgreSQL may run on the VPS initially. Use a long URL-safe password.
DATABASE_URL=postgresql://django_blog:REPLACE_WITH_DATABASE_PASSWORD@127.0.0.1:5432/django_blog

# Timeweb S3, private bucket with presigned URLs.
DJANGO_MEDIA_STORAGE=s3
MEDIA_S3_ENDPOINT_URL=https://s3.twcstorage.ru
MEDIA_S3_BUCKET_NAME=REPLACE_WITH_BUCKET_NAME
MEDIA_S3_REGION_NAME=ru-1
MEDIA_S3_AUTH_ID=REPLACE_WITH_S3_ACCESS_KEY
MEDIA_S3_AUTH_MATERIAL=REPLACE_WITH_S3_SECRET_ACCESS_KEY
MEDIA_S3_CUSTOM_DOMAIN=
MEDIA_S3_SIGNED_URLS=true
MEDIA_S3_SIGNED_URL_TTL_SECONDS=3600
MEDIA_S3_CACHE_CONTROL=private,max-age=3600
MEDIA_S3_FILE_OVERWRITE=false
MEDIA_S3_ADDRESSING_STYLE=path
MEDIA_S3_SIGNATURE_VERSION=s3v4
MEDIA_S3_VERIFY_SSL=true
