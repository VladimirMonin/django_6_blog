# Local checklist for configuring the GitHub production environment.
# Copy to .env.deploy; never commit the populated copy.
DEPLOY_HOST=REPLACE_WITH_SERVER_IPV4
DEPLOY_PORT=22
# Use a dedicated deploy account after bootstrap, not root.
DEPLOY_USER=deploy
DEPLOY_SSH_PRIVATE_KEY_FILE=REPLACE_WITH_LOCAL_PRIVATE_KEY_PATH
DEPLOY_KNOWN_HOSTS=REPLACE_WITH_OUTPUT_OF_SSH_KEYSCAN
DEPLOY_RELEASE_ROOT=/srv/django-6-blog
