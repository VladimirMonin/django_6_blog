#!/usr/bin/env python3
from __future__ import annotations

import fcntl
import json
import os
from pathlib import Path
import re
import subprocess
import tempfile
import urllib.request

API_URL = (
    "https://api.github.com/repos/VladimirMonin/django_6_blog/"
    "deployments?environment=production&per_page=20"
)
TRANSPORT = "timeweb-pull-v1"
STATE_DIR = Path("/var/lib/django-6-blog")
STATUS_PATH = STATE_DIR / "deployment-status.json"
LAST_ID_PATH = STATE_DIR / "last-deployment-id"
LOCK_PATH = Path("/run/lock/django-6-blog-deployment-poller.lock")
ADAPTER = Path("/usr/local/sbin/django-6-blog-checkout-deploy")
SHA_PATTERN = re.compile(r"^[a-f0-9]{40}$")


def atomic_write(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        os.fchmod(fd, mode)
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary, path)
    except BaseException:
        Path(temporary).unlink(missing_ok=True)
        raise


def write_status(deployment_id: int, sha: str, status: str) -> None:
    payload = {
        "deployment_id": deployment_id,
        "sha": sha,
        "status": status,
    }
    atomic_write(STATUS_PATH, json.dumps(payload, sort_keys=True) + "\n")


def fetch_requested_deployment() -> tuple[int, str] | None:
    request = urllib.request.Request(
        API_URL,
        headers={
            "Accept": "application/vnd.github+json",
            "User-Agent": "django-6-blog-production-poller/1",
            "X-GitHub-Api-Version": "2022-11-28",
        },
    )
    with urllib.request.urlopen(request, timeout=20) as response:
        deployments = json.load(response)
    if not isinstance(deployments, list):
        raise RuntimeError("unexpected deployments response")
    for deployment in deployments:
        payload = deployment.get("payload")
        if not isinstance(payload, dict) or payload.get("transport") != TRANSPORT:
            continue
        deployment_id = deployment.get("id")
        sha = deployment.get("sha")
        if not isinstance(deployment_id, int) or not isinstance(sha, str) or not SHA_PATTERN.fullmatch(sha):
            raise RuntimeError("invalid deployment request")
        return deployment_id, sha
    return None


def main() -> int:
    LOCK_PATH.parent.mkdir(parents=True, exist_ok=True)
    with LOCK_PATH.open("w", encoding="utf-8") as lock:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return 0
        requested = fetch_requested_deployment()
        if requested is None:
            return 0
        deployment_id, sha = requested
        if LAST_ID_PATH.exists() and LAST_ID_PATH.read_text(encoding="utf-8").strip() == str(deployment_id):
            return 0
        write_status(deployment_id, sha, "in_progress")
        result = subprocess.run([str(ADAPTER), sha], check=False)
        atomic_write(LAST_ID_PATH, f"{deployment_id}\n")
        write_status(deployment_id, sha, "success" if result.returncode == 0 else "failure")
        return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
