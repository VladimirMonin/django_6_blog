{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":false,"required":["schema_version","release_id","commit","created_at","python_version","django_version","gunicorn_version","migration_leaves","schema_sequence","minimum_compatible_schema_sequence","migration_safety","media_storage_mode","static_manifest_sha256"],"properties":{"schema_version":{"const":1},"release_id":{"type":"string","pattern":"^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{12}$"},"commit":{"type":"string","pattern":"^[0-9a-f]{40}$"},"created_at":{"type":"string","format":"date-time"},"python_version":{"type":"string"},"django_version":{"type":"string"},"gunicorn_version":{"type":"string"},"migration_leaves":{"type":"array","uniqueItems":true,"items":{"type":"array","prefixItems":[{"type":"string"},{"type":"string"}],"items":false}},"schema_sequence":{"type":"integer","minimum":0},"minimum_compatible_schema_sequence":{"type":"integer","minimum":0},"migration_safety":{"enum":["no-schema-change","backward-compatible","forward-only","destructive"]},"media_storage_mode":{"enum":["filesystem","s3"]},"static_manifest_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}
