# Placeholders only. Install as /etc/django-6-blog/backup.env with mode 0640.
BACKUP_EXECUTION_MODE=live
BACKUP_STATE_DIR=/var/lib/django-6-blog-backup/state
BACKUP_SCRATCH_DIR=/var/lib/django-6-blog-backup/scratch
BACKUP_EVIDENCE_DIR=/var/lib/django-6-blog-backup/evidence
BACKUP_LOCK_FILE=/run/lock/django-6-blog-backup.lock
BACKUP_SOURCE_PG_MAJOR=16
BACKUP_LIVE_APPROVAL_FILE=/etc/django-6-blog/backup-live-approved
BACKUP_AGE_RECIPIENT=replace-with-public-recipient
BACKUP_MEDIA_SOURCE=replace-with-rclone-source-alias
BACKUP_MEDIA_DESTINATION=replace-with-rclone-destination-alias
# PostgreSQL and rclone credentials are injected out of band, never stored here in Git.
