DJANGO_SETTINGS_MODULE=config.settings_production
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=<SECRET>
DATABASE_URL=<POSTGRESQL_DSN>
DJANGO_ALLOWED_HOSTS=<DOMAIN>
DJANGO_CSRF_TRUSTED_ORIGINS=https://<DOMAIN>
SITE_AUTHOR=<PUBLIC_AUTHOR_NAME>
DJANGO_MEDIA_STORAGE=s3
MEDIA_S3_ENDPOINT_URL=https://s3.twcstorage.ru
MEDIA_S3_BUCKET_NAME=<BUCKET_NAME>
MEDIA_S3_REGION_NAME=ru-1
MEDIA_S3_AUTH_ID=<S3_ACCESS_KEY>
MEDIA_S3_AUTH_MATERIAL=<S3_SECRET_ACCESS_KEY>
# Leave empty for a private bucket using presigned URLs.
MEDIA_S3_CUSTOM_DOMAIN=
MEDIA_S3_SIGNED_URLS=true
MEDIA_S3_SIGNED_URL_TTL_SECONDS=3600
MEDIA_S3_CACHE_CONTROL=private,max-age=3600
MEDIA_S3_FILE_OVERWRITE=false
MEDIA_S3_ADDRESSING_STYLE=path
MEDIA_S3_SIGNATURE_VERSION=s3v4
MEDIA_S3_VERIFY_SSL=true
