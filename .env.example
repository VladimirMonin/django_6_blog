# Local Django settings example.
# Copy this file to .env if your shell/editor loads dotenv files, or export variables manually.
# Never commit the real .env file.

# Django core settings
DJANGO_SECRET_KEY=django-insecure-local-development-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Site identity (used in templates and context processors)
SITE_AUTHOR=Your Name

# Production-only placeholders. Keep real values outside Git.
DATABASE_URL=postgresql://user:password@database.example.invalid:5432/blog
DJANGO_CSRF_TRUSTED_ORIGINS=https://blog.example.invalid
DJANGO_MEDIA_STORAGE=s3
MEDIA_S3_ENDPOINT_URL=https://s3.example.invalid
MEDIA_S3_BUCKET_NAME=replace-me
MEDIA_S3_REGION_NAME=replace-me
MEDIA_S3_AUTH_ID=replace-me
MEDIA_S3_AUTH_MATERIAL=replace-me
MEDIA_S3_CUSTOM_DOMAIN=media.example.invalid
MEDIA_S3_SIGNED_URLS=false
MEDIA_S3_SIGNED_URL_TTL_SECONDS=3600
MEDIA_S3_CACHE_CONTROL=public,max-age=86400
MEDIA_S3_FILE_OVERWRITE=false
MEDIA_S3_ADDRESSING_STYLE=path
MEDIA_S3_SIGNATURE_VERSION=s3v4
MEDIA_S3_VERIFY_SSL=true